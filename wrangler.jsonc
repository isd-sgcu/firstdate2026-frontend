{
  "name": "firstdate2026-frontend",
  "compatibility_date": "2026-07-01",
  "preview_urls": true,

  "assets": {
    "directory": "./dist",
  },

  "routes": [
    {
      "pattern": "www.cufirstdate2026.com",
      "zone_name": "cufirstdate2026.com",
    },
  ],

  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
}
