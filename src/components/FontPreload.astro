---
import kanigaRegular from "../assets/fonts/kaniga.ttf";
import kanigaBold from "../assets/fonts/kaniga_bold.ttf";
import kanigaItalic from "../assets/fonts/kaniga_italic.ttf";
import kanigaBoldItalic from "../assets/fonts/kaniga_bold_italic.ttf";
---

<link
  rel="preload"
  href={kanigaRegular}
  as="font"
  type="font/ttf"
  crossorigin
/>
<link rel="preload" href={kanigaBold} as="font" type="font/ttf" crossorigin />
<link rel="preload" href={kanigaItalic} as="font" type="font/ttf" crossorigin />
<link
  rel="preload"
  href={kanigaBoldItalic}
  as="font"
  type="font/ttf"
  crossorigin
/>
