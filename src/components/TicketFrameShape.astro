---
import type { HTMLAttributes } from "astro/types";

import { cn } from "@lib/utils";

/**
 * A rectangle whose four corners are scooped out by a quarter-circle (concave
 * "cutout" corners), built with a CSS mask so it resizes freely — the corner
 * radius stays fixed at any box size, no viewBox distortion.
 *
 * Renders only the shape — it fills its parent (`absolute inset-0`), so wrap it
 * in your own positioned container and layer content over it.
 *
 * A given shape is either filled OR stroked, never both:
 *   - `variant="fill"`   solid fill (default)
 *   - `variant="stroke"` outline only
 *
 * Both variants are a flat `background` clipped by a mask, so the concave arcs
 * are antialiased by the compositor (no jagged gradient rings).
 */

export interface Props extends HTMLAttributes<"div"> {
  /** Fill (solid) or stroke (outline only). */
  variant?: "fill" | "stroke";
  /** Colour of the fill or the stroke. Defaults to the FD/White background token. */
  color?: string;
  /** Radius of each corner cutout, in px. */
  radius?: number;
  /** Stroke width in px. Only used when `variant="stroke"`. */
  strokeWidth?: number;
}

const {
  variant = "fill",
  color = "var(--color-background)",
  radius = 40,
  strokeWidth = 2,
  class: className,
  ...props
} = Astro.props;

const CORNERS = [
  "left top",
  "right top",
  "left bottom",
  "right bottom",
] as const;

// Serialize a CSS declaration map into an inline style string, dropping any
// undefined values.
function toStyle(decls: Record<string, string | undefined>): string {
  return Object.entries(decls)
    .filter(([, v]) => v !== undefined)
    .map(([k, v]) => `${k}: ${v}`)
    .join("; ");
}

// Solid fill: a coloured box masked so a disc of `radius` is removed at each
// corner. `intersect` keeps a pixel only if every layer keeps it, so any corner
// disc carves through.
function fillStyle(color: string, r: number): Record<string, string> {
  const image = CORNERS.map(
    (pos) => `radial-gradient(circle ${r}px at ${pos}, #0000 98%, #000)`,
  ).join(", ");

  return {
    background: color,
    "mask-image": image,
    "mask-repeat": "no-repeat",
    "mask-composite": "intersect",
    "-webkit-mask-image": image,
    "-webkit-mask-repeat": "no-repeat",
    "-webkit-mask-composite": "source-in",
  };
}

// Outline: a flat background clipped to a `b`-wide ring by three mask layers.
//  - radial (repeat, full-box tile, offset -r): a circle lands on every corner
//    because each tile corner coincides with a box corner — one layer, 4 arcs.
//  - each repeat-x / repeat-y linear draws BOTH opposite edges via the wrap.
// The layers union (default `add`), so arcs and bars join into one ring. Edges
// run `2r - b` inset (extending b/2 into the corners) to overlap the arcs.
function strokeStyle(
  color: string,
  r: number,
  b: number,
): Record<string, string> {
  const image = [
    `radial-gradient(${r}px at ${r}px ${r}px, #0000 calc(98% - ${b}px), #000 calc(100% - ${b}px) 98%, #0000)`,
    `linear-gradient(90deg, #000 ${2 * b}px, #0000 0)`,
    `linear-gradient(#000 ${2 * b}px, #0000 0)`,
  ].join(", ");
  const position = [`-${r}px -${r}px`, `-${b}px 50%`, `50% -${b}px`].join(", ");
  const size = [
    "auto",
    `100% calc(100% - ${2 * r - b}px)`,
    `calc(100% - ${2 * r - b}px) 100%`,
  ].join(", ");
  const repeat = ["repeat", "repeat-x", "repeat-y"].join(", ");

  return {
    background: color,
    "mask-image": image,
    "mask-position": position,
    "mask-size": size,
    "mask-repeat": repeat,
    "-webkit-mask-image": image,
    "-webkit-mask-position": position,
    "-webkit-mask-size": size,
    "-webkit-mask-repeat": repeat,
  };
}

const shapeStyle =
  variant === "stroke"
    ? strokeStyle(color, radius, strokeWidth)
    : fillStyle(color, radius);
---

<div
  aria-hidden
  data-slot="cutout-frame-shape"
  class={cn("pointer-events-none absolute inset-0", className)}
  style={toStyle(shapeStyle)}
  {...props}
>
</div>
