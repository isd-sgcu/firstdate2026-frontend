---
import TicketFrameShape from "@components/TicketFrameShape.astro";

export interface Props {
  /** Inset the content within the safe area between the caps. */
  safeInset?: boolean;
}

const { safeInset = true } = Astro.props;
---

<div class="relative size-full">
  <div class="absolute inset-0 z-[-2]">
    <TicketFrameShape />
  </div>
  <div class="absolute inset-5 z-[-1]">
    <TicketFrameShape variant="stroke" strokeWidth={1} color="var(--primary)" />
  </div>

  <div class={safeInset ? "p-15 h-full" : ""}>
    <slot />
  </div>
</div>
