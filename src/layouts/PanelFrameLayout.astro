---
import PanelFrameShape from "@components/shared/PanelFrameShape.astro";
import { Sidebar } from "@components/shared/Sidebar";
import Image from "astro/components/Image.astro";
import logo from "../assets/images/logo_horizontal.png";
import { ChevronLeft } from "lucide-react";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  navigateBack?: string;
  showMenu?: boolean;
  showBottomCap?: boolean;
  strokeColor?: string;
  strokeWidth?: number;
  fillHeight?: boolean;
}

const {
  navigateBack = "",
  showMenu = true,
  showBottomCap = true,
  strokeColor = "var(--color-primary)",
  strokeWidth = 1,
  fillHeight = false,
  ...rest
} = Astro.props;
---

<div
  class:list={[
    "relative w-full frameContainer",
    fillHeight ? "h-svh sm:h-[calc(100svh-3rem)]" : "min-h-160",
  ]}
  {...rest}
>
  <div class="absolute inset-0 z-[-2]">
    <PanelFrameShape showBottom={showBottomCap} />
  </div>
  <div
    class:list={[
      "absolute inset-x-5 z-[-1]",
      showBottomCap ? "inset-y-6" : "top-6 bottom-0",
    ]}
  >
    <PanelFrameShape
      variant="stroke"
      strokeWidth={strokeWidth}
      color={strokeColor}
      showBottom={showBottomCap}
    />
  </div>

  <div class="absolute left-0 right-0 top-[7.5cqw] grid place-items-center">
    <Image src={logo} alt="firstdate logo" class="h-[28cqw] w-fit" />
  </div>

  {
    navigateBack && (
      <div class="absolute left-4 right-4 top-[5cqw] h-12 flex justify-between">
        <a href={navigateBack}>
          <ChevronLeft className="size-6.5 text-muted" />
        </a>
      </div>
    )
  }

  {
    showMenu && (
      <div class="absolute right-4 top-[5cqw] h-12 flex justify-between">
        <Sidebar client:load />
      </div>
    )
  }

  {
    fillHeight ? (
      <div class="absolute inset-0 flex flex-col px-[1.25em] pt-[31.35cqw]">
        <slot />
      </div>
    ) : (
      <div
        class:list={[
          "px-[1.25em] pt-[31.35cqw]",
          showBottomCap ? "pb-[31.35cqw]" : "pb-12",
        ]}
      >
        <slot />
      </div>
    )
  }
</div>

<style>
  .frameContainer {
    container-type: inline-size;
  }
</style>
