---
import BaseLayout from "@layouts/BaseLayout.astro";
import PanelFrameLayout from "@layouts/PanelFrameLayout.astro";
import { RegisterPanel } from "@components/register/RegisterPanel";
---

<BaseLayout title="Register">
  <PanelFrameLayout
    showMenu={false}
    showBottomCap={false}
    strokeColor="var(--color-fd-red)"
    strokeWidth={2}
    fillHeight
  >
    <RegisterPanel client:load />
  </PanelFrameLayout>
</BaseLayout>
